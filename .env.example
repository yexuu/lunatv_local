# LunaTV-config 本地同步服务配置
# 复制为 .env 后按需修改

# 三个版本 jin18/jingjian/full 均自动同步, 此处仅指定
# /config.json 与 /tvbox.json 默认返回哪个版本
# 可选: jin18(31源纯净) / jingjian(61源含成人) / full(88源完整)
LUNATV_DEFAULT_SOURCE=jin18

# GitHub 加速镜像前缀(远程机器访问 raw.githubusercontent.com 困难时使用)
# 示例: LUNATV_MIRROR_PREFIX=https://ghproxy.net/
LUNATV_MIRROR_PREFIX=

# HTTP 服务端口
LUNATV_PORT=8899

# 自动同步间隔(分钟), 上游每小时检测一次源状态, 默认 6 小时同步足够
LUNATV_REFRESH_MINUTES=360

# 磁盘缓存目录
LUNATV_DATA_DIR=data
